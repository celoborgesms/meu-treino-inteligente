rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Preferência v0.6.4: crie documentos de admin por UID do Firebase Auth.
    // Compatibilidade: documentos por e-mail continuam funcionando quando o e-mail do token bate exatamente com o ID.
    function isAdmin() {
      return signedIn()
        && (
          (
            exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.ativo == true
          )
          || (
            request.auth.token.email != null
            && exists(/databases/$(database)/documents/admins/$(userEmail()))
            && get(/databases/$(database)/documents/admins/$(userEmail())).data.ativo == true
          )
        );
    }

    match /usuarios/{userId} {
      allow read, create, update, delete: if isOwner(userId) || isAdmin();

      match /treinos/{docId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /corridas/{docId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /planosSemanais/{docId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /{subdocumentos=**} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // O app agora consulta /usuariosAutorizados/{uid} primeiro e /usuariosAutorizados/{email} como fallback.
    // UID evita falha de caixa alta/baixa no e-mail, porque Firestore Rules não tem lowercase().
    match /usuariosAutorizados/{docId} {
      allow read: if signedIn()
        && request.auth.token.email_verified == true
        && (
          docId == request.auth.uid
          || (request.auth.token.email != null && docId == userEmail())
        );
      allow create, update, delete: if isAdmin();
    }

    // Documento administrativo criado fora do app, pelo console do Firebase.
    // Recomendado: /admins/{uidDoTreinador}. Compatível: /admins/{emailExatoDoToken}.
    match /admins/{docId} {
      allow read: if signedIn()
        && (
          docId == request.auth.uid
          || (request.auth.token.email != null && docId == userEmail())
        );
      allow create, update, delete: if false;
    }

    match /{documento=**} {
      allow read, write: if false;
    }
  }
}
